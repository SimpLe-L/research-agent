{
  "name": "sp-agent",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.2.1",
  "scripts": {
    "dev": "concurrently -k \"pnpm --filter @sp-agent/api dev\" \"pnpm --filter @sp-agent/web dev\"",
    "dev:api": "pnpm --filter @sp-agent/api dev",
    "dev:api-only": "pnpm --filter @sp-agent/api dev:api-only",
    "dev:web": "pnpm --filter @sp-agent/web dev",
    "worker:research": "pnpm --filter @sp-agent/api worker",
    "start:worker:research": "pnpm --filter @sp-agent/api start:worker",
    "dev:desktop": "pnpm build && pnpm --filter @sp-agent/desktop start",
    "electron:install": "ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ electron_config_cache=.electron-cache node apps/desktop/node_modules/electron/install.js",
    "db:up": "docker compose up -d postgres",
    "db:psql": "docker exec -it sp-agent-postgres psql -U sp_agent -d sp_agent",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "smoke:api": "node scripts/api-smoke.mjs",
    "smoke:api:chat": "node scripts/api-chat-smoke.mjs",
    "smoke:api:live-providers": "node scripts/api-live-provider-smoke.mjs",
    "smoke:api:coingecko-public": "node scripts/api-coingecko-public-smoke.mjs",
    "smoke:api:pending-requeue": "node scripts/api-pending-requeue-smoke.mjs",
    "smoke:api:worker": "node scripts/api-worker-smoke.mjs",
    "smoke:api:agent-worker": "node scripts/api-agent-worker-smoke.mjs",
    "smoke:api:extensions": "node scripts/api-extensions-smoke.mjs",
    "smoke:api:pi-runtime": "node scripts/api-pi-runtime-smoke.mjs",
    "smoke:api:pi-research-rag": "node scripts/api-pi-research-rag-smoke.mjs",
    "smoke:research-rag": "node scripts/research-rag-smoke.mjs",
    "smoke:agent-runtime": "node scripts/agent-runtime-smoke.mjs",
    "smoke:agent-runtime:pi": "node scripts/agent-runtime-pi-smoke.mjs",
    "smoke:web:routes": "node scripts/web-route-smoke.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  }
}
