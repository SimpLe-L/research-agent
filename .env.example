NODE_ENV=development
PORT=4317
DATABASE_URL=postgres://sp_agent:sp_agent@localhost:54329/sp_agent
RESEARCH_TASK_EXECUTOR_MODE=local
RESEARCH_TASK_QUEUE_CONCURRENCY=2
RESEARCH_WORKER_POLL_INTERVAL_MS=2000
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=Qwen/Qwen2.5-72B-Instruct
SILICONFLOW_EMBEDDING_MODEL=BAAI/bge-m3
# Research Planner and evidence-constrained synthesis use the same SiliconFlow key.
RESEARCH_INTELLIGENCE_MODEL=deepseek-ai/DeepSeek-V4-Flash
RESEARCH_INTELLIGENCE_TIMEOUT_MS=60000
TAVILY_API_KEY=
TAVILY_SEARCH_URL=https://api.tavily.com/search

# Crypto investment research connectors. Set each URL and key only after choosing a
# provider with a documented response contract; empty values keep the skill in an
# explicit evidence-insufficient state instead of fabricating market data.
CRYPTO_MARKET_DATA_URL=
CRYPTO_MARKET_DATA_API_KEY=
CRYPTO_FEAR_GREED_URL=
CRYPTO_FEAR_GREED_API_KEY=
CRYPTO_ETF_FLOWS_URL=
CRYPTO_ETF_FLOWS_API_KEY=
CRYPTO_ONCHAIN_URL=
CRYPTO_ONCHAIN_API_KEY=
MEMORY_VECTOR_PROVIDER=
# Leave empty to use SiliconFlow automatically when SILICONFLOW_API_KEY is present,
# otherwise fall back to deterministic embeddings for offline smoke tests.
MEMORY_EMBEDDING_PROVIDER=
MEMORY_LANCEDB_URI=.sp-agent-data/lancedb
MEMORY_EMBEDDING_TIMEOUT_MS=30000
# Pi is the default Agent runtime. SiliconFlow is the default Pi model provider.
AGENT_RUNTIME_PROVIDER=pi
# Empty PI_MODEL_PROVIDER/PI_MODEL_ID defaults to this SiliconFlow model.
PI_MODEL_PROVIDER=siliconflow
PI_MODEL_ID=deepseek-ai/DeepSeek-V4-Flash
PI_SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V4-Flash
PI_AGENT_RUNTIME_TIMEOUT_MS=240000
PI_THINKING_LEVEL=off
PI_WORKING_DIR=
AGENT_RUNTIME_TIMEOUT_MS=20000

# Speech providers are optional. Typed chat remains usable when these are empty.
# Deterministic providers are for local smoke tests:
# SPEECH_STT_PROVIDER=deterministic
# SPEECH_TTS_PROVIDER=deterministic
SPEECH_STT_PROVIDER=
SPEECH_TTS_PROVIDER=

# OpenAI-compatible STT endpoint. This can point at a local wrapper around FunASR/SenseVoice
# or a hosted OpenAI-style audio/chat-completions endpoint.
# Recommended for FunASR official OpenAI-compatible server:
# SPEECH_STT_PROVIDER=openai-audio-transcriptions-stt
OPENAI_TRANSCRIPTIONS_STT_URL=http://127.0.0.1:8000/v1/audio/transcriptions
OPENAI_TRANSCRIPTIONS_STT_MODEL=sensevoice
OPENAI_TRANSCRIPTIONS_STT_API_KEY=
OPENAI_TRANSCRIPTIONS_STT_RESPONSE_FORMAT=verbose_json
OPENAI_TRANSCRIPTIONS_STT_LANGUAGE=
OPENAI_TRANSCRIPTIONS_STT_FILENAME=audio.webm

# Alternative chat-completions-style STT adapter:
OPENAI_COMPATIBLE_STT_URL=
OPENAI_COMPATIBLE_STT_API_KEY=
OPENAI_COMPATIBLE_STT_MODEL=

# Cloud TTS adapter. Use this when the local machine cannot run GPT-SoVITS.
# SPEECH_TTS_PROVIDER=minimax-t2a-v2
MINIMAX_TTS_URL=https://api.minimax.chat/v1/t2a_v2
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
# Keep the model configurable so newer MiniMax HD models can be selected without code changes.
MINIMAX_TTS_MODEL=speech-02-hd
MINIMAX_TTS_VOICE_ID=
MINIMAX_TTS_SPEED=1
MINIMAX_TTS_VOLUME=1
MINIMAX_TTS_PITCH=0
MINIMAX_TTS_SAMPLE_RATE=32000
MINIMAX_TTS_BITRATE=128000
MINIMAX_TTS_FORMAT=mp3
MINIMAX_TTS_CHANNEL=1

# Xiaomi MiMo cloud TTS adapter.
# SPEECH_TTS_PROVIDER=mimo-v2.5-tts
MIMO_TTS_URL=https://api.xiaomimimo.com/v1/chat/completions
MIMO_API_KEY=
MIMO_TTS_MODEL=mimo-v2.5-tts
MIMO_TTS_VOICE=mimo_default
MIMO_TTS_FORMAT=mp3
MIMO_TTS_STYLE_PROMPT=

# Optional local GPT-SoVITS /tts API. MoeChat's documented default is http://127.0.0.1:9880/tts.
# SPEECH_TTS_PROVIDER=gpt-sovits-api
GPT_SOVITS_TTS_URL=http://127.0.0.1:9880/tts
GPT_SOVITS_REF_AUDIO_PATH=
GPT_SOVITS_PROMPT_TEXT=
GPT_SOVITS_TEXT_LANG=zh
GPT_SOVITS_PROMPT_LANG=zh
GPT_SOVITS_TEXT_SPLIT_METHOD=cut0
GPT_SOVITS_MIME_TYPE=audio/wav

# Explicit live speech smoke. Keep disabled unless local/remote STT and TTS providers are ready.
SPEECH_PROVIDER_LIVE_SMOKE=0
SPEECH_LIVE_AUDIO_BASE64=
SPEECH_LIVE_AUDIO_MIME_TYPE=audio/webm
SPEECH_LIVE_TTS_TEXT="语音 live smoke 测试。"

COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
# Optional future upgrade for demo/pro keys.
COINGECKO_API_KEY=
# COINGECKO_API_KEY_HEADER=x-cg-demo-api-key
DEFILLAMA_BASE_URL=https://api.llama.fi
DATA_CONNECTOR_TIMEOUT_MS=10000
ETHEREUM_RPC_URL=
BASE_RPC_URL=
ARBITRUM_RPC_URL=
BSC_RPC_URL=
POLYGON_RPC_URL=
DUNE_API_KEY=
THE_GRAPH_API_KEY=
HOLDER_CONCENTRATION_PROVIDER=etherscan
HOLDER_CONCENTRATION_URL_TEMPLATE=
HOLDER_CONCENTRATION_API_KEY=
HOLDER_CONCENTRATION_AUTH_HEADER_NAME=Authorization
HOLDER_CONCENTRATION_AUTH_SCHEME=Bearer
ETHERSCAN_API_KEY=
ETHERSCAN_BASE_URL=https://api.etherscan.io/v2/api
ETHERSCAN_HOLDER_ACTION=topholders
ETHERSCAN_HOLDER_OFFSET=100
ARKHAM_API_KEY=
ARKHAM_BASE_URL=https://api.arkhamintelligence.com
ARKHAM_AUTH_HEADER_NAME=API-Key
ARKHAM_AUTH_SCHEME=
ARKHAM_VERIFY_URL_TEMPLATE=
ARKHAM_ADDRESS_LABEL_URL_TEMPLATE=
ARKHAM_ADDRESS_TRANSFERS_URL_TEMPLATE=
ARKHAM_ADDRESS_HOLDINGS_URL_TEMPLATE=
ARKHAM_WEB_ADDRESS_URL_TEMPLATE=https://platform.arkhamintelligence.com/explorer/address/{address}
